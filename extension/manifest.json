{
  "manifest_version": 3,
  "name": "WhatsApp passkey (whatsmeow)",
  "version": "1.2",
  "description": "Verifica a passkey da conta e assina o vínculo do whatsmeow, tudo no web.whatsapp.com.",
  "host_permissions": [
    "http://127.0.0.1:7799/*",
    "https://web.whatsapp.com/*"
  ],
  "action": { "default_title": "WhatsApp passkey (whatsmeow)" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
